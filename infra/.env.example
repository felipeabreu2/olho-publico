# ─── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=olho
POSTGRES_PASSWORD=changeme

# ─── Domínios (Traefik) ──────────────────────────────────────────────
# Host público que Traefik vai rotear para o container web.
WEB_HOST=olho.optiongrowth.com.br
SITE_URL=https://olho.optiongrowth.com.br

# ─── Imagens Docker (GHCR) ───────────────────────────────────────────
GITHUB_REPO=felipeabreu2/olho-publico

# ─── ETL ─────────────────────────────────────────────────────────────
TRANSPARENCIA_API_KEY=
# 400 = padrão diurno seguro 24/7. Pode subir para 700 entre 00h-06h se rodar
# sync programado nesse horário. APIs restritas (auxílio, bolsa família por
# beneficiário) exigem 180.
TRANSPARENCIA_RATE_PER_MINUTE=400
# IMPORTANTE: API CGU bloqueia IPs não-BR. Se VPS está fora do Brasil, use um
# proxy (ex.: Cloudflare Worker em https://transparencia-proxy.SEU.workers.dev)
# e aponte aqui. Veja docs/PROXY-CGU.md para o setup.
TRANSPARENCIA_BASE_URL=https://api.portaldatransparencia.gov.br
# Lista CSV de IBGE para sync (default: 10 capitais brasileiras).
# Adicione mais cidades aqui se quiser cobertura maior.
IBGE_SYNC_LIST=3550308,3304557,5300108,2304400,2927408,3106200,1302603,4106902,2611606,5208707
# Quantos meses de histórico sincronizar a cada ciclo de 24h.
SYNC_MESES_LOOKBACK=12

# ─── Cloudflare R2 (storage) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RAW=olho-publico-raw
R2_BUCKET_BRONZE=olho-publico-bronze
R2_BUCKET_BACKUPS=olho-publico-backups
