{
  "name": "olho-publico",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @olho/db generate",
    "db:migrate": "pnpm --filter @olho/db migrate"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "prettier": "^3.3.0"
  }
}
